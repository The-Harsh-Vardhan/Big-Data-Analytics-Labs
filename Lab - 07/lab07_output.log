#################################################################
##  PART B - Apache Hive (SQL-on-Hadoop Data Warehouse)
#################################################################
  [!]   Hive requires Hadoop HDFS to be running.
  [!]   Start Hadoop:  start-dfs.sh && start-yarn.sh
  [!]   Then run HiveQL commands:  hive -f lab07_hive.hql
  [!]   HiveQL commands are shown below for reference:

-----------------------------------------------------------------
  STEP 1 - CREATE DATABASE & TABLE
-----------------------------------------------------------------
     hive> CREATE DATABASE IF NOT EXISTS student_db;
     hive> USE student_db;
     hive> CREATE TABLE IF NOT EXISTS students (
     hive>     id INT, name STRING, department STRING, marks INT
     hive> ) ROW FORMAT DELIMITED FIELDS TERMINATED BY ',' STORED AS TEXTFILE;

  >>  Expected Output
  .............................................................
     OK
     Time taken: 0.x seconds

-----------------------------------------------------------------
  STEP 2 - LOAD DATA & RETRIEVE
-----------------------------------------------------------------
     hive> LOAD DATA LOCAL INPATH '/tmp/students.csv' INTO TABLE students;
     hive> SELECT * FROM students;

  >>  Expected Output
  .............................................................
  +-----+----------------+-------+-------+
  | ID  | Name           | Dept  | Mark  |
  +-----+----------------+-------+-------+
  | 1   | Amit Kumar     | CSE   | 85    |
  | 2   | Neha Sharma    | IT    | 90    |
  | 3   | Ravi Verma     | CSE   | 72    |
  | 4   | Priya Singh    | ECE   | 88    |
  | 5   | Arjun Patel    | CSE   | 94    |
  | 6   | Sneha Gupta    | IT    | 76    |
  | 7   | Karan Mehta    | ECE   | 63    |
  | 8   | Divya Joshi    | CSE   | 91    |
  | 9   | Rohit Das      | IT    | 55    |
  | 10  | Meera Nair     | ECE   | 82    |
  +-----+----------------+-------+-------+

-----------------------------------------------------------------
  STEP 3 - ANALYSIS QUERIES
-----------------------------------------------------------------

  >>  Students with marks > 80
  .............................................................
     hive> SELECT * FROM students WHERE marks > 80;
  +----------------+-------+-------+
  | Name           | Dept  | Marks |
  +----------------+-------+-------+
  | Amit Kumar     | CSE   | 85    |
  | Neha Sharma    | IT    | 90    |
  | Priya Singh    | ECE   | 88    |
  | Arjun Patel    | CSE   | 94    |
  | Divya Joshi    | CSE   | 91    |
  | Meera Nair     | ECE   | 82    |
  +----------------+-------+-------+

  >>  Average marks per department  (GROUP BY)
  .............................................................
     hive> SELECT department, AVG(marks) AS avg_marks
     hive> FROM students GROUP BY department ORDER BY avg_marks DESC;
  +--------------+------------+
  | Department   | Avg Marks  |
  +--------------+------------+
  | CSE          | 85.50      |
  | ECE          | 77.67      |
  | IT           | 73.67      |
  +--------------+------------+

  >>  Count per department
  .............................................................
     hive> SELECT department, COUNT(*) AS student_count FROM students GROUP BY department;
  +--------------+---------+
  | Department   | Count   |
  +--------------+---------+
  | CSE          | 4       |
  | ECE          | 3       |
  | IT           | 3       |
  +--------------+---------+

  >>  Top scorer
  .............................................................
     hive> SELECT * FROM students ORDER BY marks DESC LIMIT 1;
     Arjun Patel  | CSE | 94
